        "watch": "tsc -b tsconfig.build.json -w"
    },
    "dependencies": {
        "@grpc/grpc-js": "^1.12.0",
        "@grpc/proto-loader": "^0.7.0"
    },
    "devDependencies": {
        "@types/node": "^20.0.0"
    }
}
