{
    "name": "@dev/grpc",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "build": "npm run clean && npm run compile",
        "clean": "rimraf dist && rimraf tsconfig.build.tsbuildinfo",
